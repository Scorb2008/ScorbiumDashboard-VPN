# =============================================================================
#  VPN Dashboard — Environment Configuration
#  All required variables are listed below. Copy this file to .env and fill in.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Scorbium Dashboard VPN
APP_VERSION=1.6.1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ALLOWED_ORIGINS=["https://your-domain.com"]

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED! Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret
# Persistent key for encrypting secrets stored in DB.
# Do not change it on an existing install unless you also migrate secrets.
ENCRYPTION_KEY=
# Optional old key used only for decrypting legacy DB secrets after rotation/migration.
ENCRYPTION_KEY_PREVIOUS=

# Metrics API key (optional - if set, /metrics endpoint requires Bearer token)
METRICS_API_KEY=

# Legacy superadmin credentials (used for first login + DB seeding)
# CHANGE THESE after first login
WEB_SUPERADMIN_USERNAME=admin
WEB_SUPERADMIN_PASSWORD=

# Sentry DSN (optional - for error tracking)
SENTRY_DSN=
SENTRY_ENV=production

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated list of admin Telegram user IDs
TELEGRAM_ADMIN_IDS=[]
# "webhook" for production, "long" for development (polling)
TELEGRAM_TYPE_PROTOCOL=webhook
# Full URL for Telegram to send updates to (production only)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/bot
TELEGRAM_WEBHOOK_PATH=/webhook/bot

# ── VPN Panel (Marzban / Pasarguard) ──────────────────────────────────────────
PASARGUARD_ADMIN_PANEL=https://panel.example.com:8012
PASARGUARD_ADMIN_LOGIN=admin
PASARGUARD_ADMIN_PASSWORD=
PASARGUARD_API_KEY=
VPN_PANEL_TYPE=marzban

# ── Database ──────────────────────────────────────────────────────────────────
DB_ENGINE=postgresql
DB_NAME=vpnbot
DB_HOST=db
DB_PORT=5432
# External host port for PostgreSQL published by Docker.
DB_EXTERNAL_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# ── Payment Systems ────────────────────────────────────────────────────────────
# YooKassa and other payment provider credentials are configured in the admin
# panel and stored in the database.
# CryptoBot token can still be auto-seeded on first start if set here.
CRYPTOBOT_TOKEN=

# ── Domain / SSL ──────────────────────────────────────────────────────────────
HTTPS_PORT=443
DOMAIN=your-domain.com
# Admin panel path. Preferred env name is ADMIN_PATH.
# SET_PATH_ADMIN is still supported for backward compatibility.
ADMIN_PATH=/panel/

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_PATH=logs
LOG_ROTATION=1 day
LOG_RETENTION=30 days
LOG_LEVEL=INFO

# ── Redis (optional - enables shared production rate limiting) ────────────────
# If you enable the optional Redis service in docker-compose.prod.yml
# via `docker compose -f docker-compose.prod.yml --profile redis up -d`,
# use:
# REDIS_URL=redis://redis:6379/0
REDIS_URL=
